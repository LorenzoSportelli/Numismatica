const goToSlide = (index) => {
  if (!state.featuredCoins.length) return;
  
  // Clear flip timeout
  clearTimeout(state.flipTimeout);
  
  // Unflip all coins
  $$('.coin-flipper').forEach(f => f.classList.remove('flipped'));
  
  state.currentSlide = (index + state.featuredCoins.length) % state.featuredCoins.length;
  
  const track = $('slideshowTrack');
  if (track) {
    track.style.transform = translateX(-${state.currentSlide  100}%);
  }
  
  // Update dots
  $$('.slideshow-dot').forEach((dot, i) => {
    dot.classList.toggle('active', i === state.currentSlide);
  });
  
  // Update slides
  $$('.slide').forEach((slide, i) => {
    slide.classList.toggle('active', i === state.currentSlide);
  });
  
  // Start progress
  startSlideProgress();
  
  // Auto flip after delay
  state.flipTimeout = setTimeout(() => {
    const flipper = $(slideFlip${state.currentSlide});
    if (flipper) flipper.classList.add('flipped');
  }, CONSTANTS.SLIDEFLIPDELAY);
};

const startSlideProgress = () => {
  const progress = $('slideshowProgress');
  if (!progress) return;
  
  progress.style.transition = 'none';
  progress.style.width = '0%';
  
  requestAnimationFrame(() => {
    progress.style.transition = width ${CONSTANTS.SLIDEINTERVAL}ms linear;
    progress.style.width = '100%';
  });
};

const startSlideshow = () => {
  if (state.slideInterval) clearInterval(state.slideInterval);
  
  state.slideInterval = setInterval(() => {
    if (Date.now() < state.slidePauseUntil) return;
    goToSlide(state.currentSlide + 1);
  }, CONSTANTS.SLIDEINTERVAL);
};

const pauseSlideshow = () => {
  state.slidePauseUntil = Date.now() + CONSTANTS.SLIDEPAUSEDURATION;
  
  const progress = $('slideshowProgress');
  if (progress) {
    progress.style.transition = 'none';
    progress.style.width = '0%';
  }
  
  // Unflip current coin
  clearTimeout(state.flipTimeout);
  $$('.coin-flipper').forEach(f => f.classList.remove('flipped'));
};

const initSlideshowSwipe = () => {
  const container = $('slideshowContainer');
  if (!container) return;
  
  let startX = 0;
  let startY = 0;
  let isDragging = false;
  
  container.addEventListener('touchstart', (e) => {
    startX = e.touches[0].clientX;
    startY = e.touches[0].clientY;
    isDragging = true;
  }, { passive: true });
  
  container.addEventListener('touchmove', (e) => {
    if (!isDragging) return;
    const dx = e.touches[0].clientX - startX;
    const dy = e.touches[0].clientY - startY;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
      e.preventDefault();
    }
  }, { passive: false });
  
  container.addEventListener('touchend', (e) => {
    if (!isDragging) return;
    isDragging = false;
    
    const dx = e.changedTouches[0].clientX - startX;
    const dy = e.changedTouches[0].clientY - startY;
    
    if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)  1.5) {
      pauseSlideshow();
      goToSlide(dx < 0 ? state.currentSlide + 1 : state.currentSlide - 1);
    }
  }, { passive: true });
};

