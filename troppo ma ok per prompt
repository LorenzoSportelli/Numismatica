   ============================================================ */
const setupScrollEffects = () => {
  // Header scroll behavior
  let lastScrollY = 0;
  let ticking = false;
  
  const handleScroll = () => {
    const currentScrollY = window.scrollY;
    const header = $('mainHeader');
    const backToTop = $('backToTop');
    const progressBar = $('readingProgressBar');
    
    // Header state
    if (header) {
      header.classList.toggle('scrolled', currentScrollY > 60);
      
      // Hide/show header on scroll direction
      if (currentScrollY > CONSTANTS.HEADER_HIDE_THRESHOLD) {
        if (currentScrollY > lastScrollY && !state.headerHidden) {
          header.classList.add('hidden');
          state.headerHidden = true;
        } else if (currentScrollY < lastScrollY && state.headerHidden) {
          header.classList.remove('hidden');
          state.headerHidden = false;
        }
      } else {
        header.classList.remove('hidden');
        state.headerHidden = false;
      }
    }
    
    // Back to top button
    if (backToTop) {
      backToTop.classList.toggle('visible', currentScrollY > CONSTANTS.SCROLL_THRESHOLD);
    }
    
    // Reading progress
    if (progressBar) {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = (currentScrollY / docHeight) * 100;
      progressBar.style.width = `${Math.min(progress, 100)}%`;
    }
    
    lastScrollY = currentScrollY;
    ticking = false;
  };
  
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(handleScroll);
      ticking = true;
    }
  }, { passive: true });
  
  // Parallax effect on hero background
  window.addEventListener('scroll', throttle(() => {
    const heroBg = $('heroBg');
    if (heroBg && window.scrollY < window.innerHeight) {
      heroBg.style.transform = `scale(1.05) translateY(${window.scrollY * 0.2}px)`;
    }
  }, 16), { passive: true });
};
const scrollToTop = () => {
  window.scrollTo({ top: 0, behavior: 'smooth' });
};
/* ============================================================
   SEZIONE JS 27 — INTERSECTION OBSERVER
   ============================================================ */
const setupIntersectionObserver = () => {
  const observerOptions = {
    root: null,
    rootMargin: '0px 0px -100px 0px',
    threshold: 0.1
  };
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);
  
  // Observe all scroll-reveal elements
  $$('.scroll-reveal, .scroll-reveal-left, .scroll-reveal-right, .scroll-reveal-scale').forEach(el => {
    observer.observe(el);
  });
  
  // Active nav link based on section
  const navObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        updateActiveNavLink(id);
      }
    });
  }, { rootMargin: '-50% 0px -50% 0px' });
  
  ['home', 'vetrina', 'catalogo', 'tipologie', 'ordini', 'garanzie', 'faq', 'contatti'].forEach(id => {
    const section = $(id);
    if (section) navObserver.observe(section);
  });
};
const updateActiveNavLink = (sectionId) => {
  $$('.nav-link, .mobile-nav-link').forEach(link => {
    const href = link.getAttribute('href');
    link.classList.toggle('active', href === `#${sectionId}`);
  });
};
/* ============================================================
   SEZIONE JS 28 — COUNTER ANIMATION
   ============================================================ */
const animateCounters = () => {
  $$('.hero-stat-value').forEach(el => {
    const text = el.textContent.trim();
    const num = parseFloat(text.replace(/[^0-9.]/g, ''));
    
    if (!num || isNaN(num)) return;
    
    const suffix = text.replace(/[0-9.]/g, '');
    let start = null;
    const duration = 1500;
    
    const step = (timestamp) => {
      if (!start) start = timestamp;
      const progress = Math.min((timestamp - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3); // easeOutCubic
      
      el.textContent = Math.round(num * eased) + suffix;
      
      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        el.textContent = text; // Restore original
      }
    };
    
    requestAnimationFrame(step);
  });
};
