      <a href="#catalogo" class="nav-link" data-nav="catalogo">Catalogo</a>
      <a href="#tipologie" class="nav-link" data-nav="tipologie">Tipologie</a>
      <a href="#ordini" class="nav-link" data-nav="ordini">Ordini</a>
      <a href="#garanzie" class="nav-link" data-nav="garanzie">Garanzie</a>
      <a href="#faq" class="nav-link" data-nav="faq">FAQ</a>
