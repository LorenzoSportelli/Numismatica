    btn.addEventListener('mousemove', (e) => {
      const rect = btn.getBoundingClientRect();
      const x = (e.clientX - rect.left - rect.width / 2) * 0.2;
      const y = (e.clientY - rect.top - rect.height / 2) * 0.2;
      btn.style.transform = `translate(${x}px, ${y}px) translateY(-2px)`;
    });
    
    btn.addEventListener('mouseleave', () => {
      btn.style.transform = '';
    });
  });
};
/* ============================================================
   SEZIONE JS 34 — CURSOR GLOW EFFECT
   ============================================================ */
const initCursorGlow = () => {
  const glow = document.createElement('div');
  glow.style.cssText = `
    position: fixed;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    transition: transform .08s linear, opacity .3s;
    background: radial-gradient(circle, rgba(200,169,81,.06) 0%, transparent 70%);
    transform: translate(-50%, -50%);
    opacity: 0;
  `;
  document.body.appendChild(glow);
  
  let visible = false;
  
  window.addEventListener('mousemove', (e) => {
    glow.style.transform = `translate(calc(${e.clientX}px - 50%), calc(${e.clientY}px - 50%))`;
    if (!visible) {
      glow.style.opacity = '1';
      visible = true;
    }
  }, { passive: true });
  
  window.addEventListener('mouseleave', () => {
    glow.style.opacity = '0';
    visible = false;
  });
};
