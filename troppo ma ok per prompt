         state.featuredCoins.find(c => c.slug === slug);
};

const addToCart = (slug) => {
  const coin = findCoin(slug);
  if (!coin) return;
  
  const existing = state.cart.find(item => item.slug === slug);
  
  if (existing) {
    existing.qty++;
  } else {
    state.cart.push({
      slug: coin.slug,
      name: coin.name,
      price: +coin.price,
      metal: coin.metal,
      img: coin.obverseImg,
      qty: 1
    });
  }
  
  renderCart();
  openCart();
  
  showToast({
    type: 'success',
    title: 'Aggiunto al carrello',
    message: ${coin.name} è stato aggiunto al carrello.
  });
};

const removeFromCart = (slug) => {
  state.cart = state.cart.filter(item => item.slug !== slug);
  renderCart();
  
  showToast({
    type: 'info',
    title: 'Rimosso dal carrello',
    message: 'L\'articolo è stato rimosso.'
  });
};

const updateCartQuantity = (slug, delta) => {
  const item = state.cart.find(i => i.slug === slug);
  if (!item) return;
  
  item.qty += delta;
  
  if (item.qty <= 0) {
    removeFromCart(slug);
  } else {
    renderCart();
  }
};

