const applyFilters = () => {
  let filtered = [...state.coins];
  
  const search = ($('searchInput')?.value || '').toLowerCase().trim();
  const metal = $('metalFilter')?.value || '';
  const area = $('areaFilter')?.value || '';
  const sort = $('sortFilter')?.value || '';
  
  // Search filter
  if (search) {
    filtered = filtered.filter(c => 
      [c.name, c.category, c.metal, c.area, c.description, c.period]
        .some(v => (v || '').toLowerCase().includes(search))
    );
  }
  
  // Metal filter
  if (metal) {
    filtered = filtered.filter(c => (c.metal || '').includes(metal));
  }
  
  // Area filter
  if (area) {
    filtered = filtered.filter(c => c.area === area);
  }
  
  // Sorting
  switch (sort) {
    case 'pa':
      filtered.sort((a, b) => a.price - b.price);
      break;
    case 'pd':
      filtered.sort((a, b) => b.price - a.price);
      break;
    case 'na':
      filtered.sort((a, b) => (a.name || '').localeCompare(b.name || ''));
      break;
    case 'nd':
      filtered.sort((a, b) => (b.name || '').localeCompare(a.name || ''));
      break;
  }
  
  // Pagination
  const hasFilters = search || metal || area;
  const displayList = (hasFilters || state.catalogExpanded) 
    ? filtered 
    : filtered.slice(0, CONSTANTS.CATALOGINITIALLIMIT);
  
  renderCoins(displayList);
  
  // Show/hide expand button
  const expandWrapper = $('expandWrapper');
  if (expandWrapper) {
    expandWrapper.style.display = (filtered.length > CONSTANTS.CATALOGINITIALLIMIT && !hasFilters) ? 'block' : 'none';
  }
};

const toggleCatalogExpand = () => {
  state.catalogExpanded = !state.catalogExpanded;
  
  const expandText = $('expandText');
  const expandIcon = $('expandIcon');
  
  if (expandText) expandText.textContent = state.catalogExpanded ? 'Mostra meno' : 'Mostra tutte le monete';
  if (expandIcon) expandIcon.textContent = state.catalogExpanded ? '↑' : '↓';
  
  applyFilters();
  
  if (!state.catalogExpanded) {
