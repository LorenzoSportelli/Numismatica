  }
}

@keyframes skeletonPulse {
  0% { background-position: -200px 0; }
  100% { background-position: calc(200px + 100%) 0; }
}

@keyframes parallaxScroll {
  to { transform: translateY(var(--parallax-offset, 0)); }
}

@keyframes marquee {
  from { transform: translateX(0); }
