    transform: scale(1.15) translate(-2%, -1%); 
  }
}

@keyframes coinShimmer {
  to { transform: rotate(360deg); }
}

@keyframes progressBar {
  from { width: 0%; }
  to { width: 100%; }
}

@keyframes toastIn {
